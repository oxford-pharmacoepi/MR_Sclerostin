for(i in 1:ceiling(k)){
  snps1 <- snps[(1:pf)+(i-1)*pf]

  snp_locations <- biomaRt::getBM(attributes = c("refsnp_id", "chr_name", "chrom_start"),
                                  filters    = "snp_filter",
                                  values     = snps1,
                                  mart       = biomaRt::useMart("ENSEMBL_MART_SNP", dataset="hsapiens_snp"))
  snps_locations <- tibble::as_tibble(snp_locations) %>%
    dplyr::mutate(chr_name = as.character(chr_name)) %>%
    dplyr::filter(chr_name == "17")
  table_locations <- snps_locations

  table_locations <- table_locations %>%
    dplyr::rename(SNP = refsnp_id,
                  chr = chr_name,
                  pos = chrom_start)
  readr::write_tsv(table_locations,paste0(pathResults,"InstrumentSelection/MappingGRCh38_",i*pf,".txt"))
}


